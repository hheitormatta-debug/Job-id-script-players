local function ensureFolder()
    pcall(makefolder, jobIdFolder)
end

local function saveToFile()
    ensureFolder()
    pcall(writefile, jobIdFile, HttpService:JSONEncode(_G.SavedJobIds))
end

local function loadFromFile()
    pcall(function()
        if isfile(jobIdFile) then
            local success, data = pcall(HttpService.JSONDecode, HttpService, readfile(jobIdFile))
            if success and typeof(data) == "table" then
                _G.SavedJobIds = data
            end
        end
    end)
end


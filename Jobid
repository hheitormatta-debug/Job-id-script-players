local function getServers(onFound)
    statusLabel.Text = "⏳ Searching servers..."
    task.spawn(function()
        local servers, success = fetchAllServers()
        if not success or #servers == 0 then
            statusLabel.Text = "❌ Could not fetch servers."
            return
        end
        onFound(servers)
    end)
end

fewBtn.MouseButton1Click:Connect(function()
    getServers(function(data)
        if #data == 0 then
            statusLabel.Text = "❌ No servers found."
            return
        end
        table.sort(data, function(a, b) return a.playing < b.playing end)
        local target = data[1]
        statusLabel.Text = "✅ Joining server with " .. target.playing .. "/" .. target.maxPlayers .. " players..."
        task.wait(1)
        TeleportService:TeleportToPlaceInstance(game.PlaceId, target.id, player)
    end)
end)


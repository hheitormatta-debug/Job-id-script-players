        if #data == 0 then
            statusLabel.Text = "❌ No servers found."
            return
        end
        table.sort(data, function(a, b)
            local aScore = math.abs((a.maxPlayers - 1) - a.playing)
            local bScore = math.abs((b.maxPlayers - 1) - b.playing)
            return aScore < bScore
        end)

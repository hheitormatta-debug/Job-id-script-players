    local apiurl = "https://games.roblox.com/v1/games/" .. placeid .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true"
    local success, result = pcall(game.HttpGet, game, apiurl)
    
    if success and result then
        local body = HttpService:JSONDecode(result)
        local targetserver = nil
        
        if body and body.data then
            for _, server in ipairs(body.data) do
                if server.id ~= currentjob then
                    if animalBlacklistEnabled then
                        if not table.find(animalBlacklist, server.id) and server.playing < server.maxPlayers then
                            targetserver = server.id
                            break
                        end
                    else
                        if server.playing < server.maxPlayers then
                            targetserver = server.id
                            break
                        end
                    end
                end
            end
        end
        
        if targetserver then
            TeleportService:TeleportToPlaceInstance(placeid, targetserver, player)
        end
    end
end)


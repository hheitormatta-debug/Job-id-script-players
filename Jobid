local function fetchAllServers()
    local servers = {}
    local cursor = ""
    local pages = 0
    local anySuccess = false
    repeat
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        if cursor ~= "" then
            url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
        end
        local success, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if not success or not result or not result.data then
            break
        end
        anySuccess = true
        for _, server in ipairs(result.data) do
            table.insert(servers, server)
        end
        cursor = result.nextPageCursor
        pages = pages + 1
    until not cursor or cursor == "" or pages >= 10
    return servers, anySuccess
end

updatePlayerCounts = function()
    if isUpdatingPlayerCounts then
        return
    end
    isUpdatingPlayerCounts = true

    local servers, success = fetchAllServers()
    if not success then
        isUpdatingPlayerCounts = false
        return
    end

    local lookup = {}
    for _, server in ipairs(servers) do
        lookup[server.id] = server
    end

    local toRemove = {}
    for _, saved in ipairs(_G.SavedJobIds) do
        if saved.gameName == gameName then
            local server = lookup[saved.jobId]
            if server then
                local label = playerCountLabels[saved.label]
                if label then
                    label.Text = "👥 Players: " .. server.playing .. "/" .. server.maxPlayers
                end
                if server.playing <= 0 then
                    table.insert(toRemove, saved.label)
                end
            else
                table.insert(toRemove, saved.label)
            end
        end
    end

    if #toRemove > 0 then
        for _, labelToRemove in ipairs(toRemove) do
            for i = #_G.SavedJobIds, 1, -1 do
                if _G.SavedJobIds[i].label == labelToRemove then
                    table.remove(_G.SavedJobIds, i)
                    break
                end
            end
        end
        saveToFile()
        isUpdatingPlayerCounts = false
        refreshSavedList()
        return
    end

    isUpdatingPlayerCounts = false
end

